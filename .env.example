# ============================================================================
#  CONTOH FILE ENVIRONMENT
# ----------------------------------------------------------------------------
#  1. Salin file ini menjadi ".env"  (perintah:  cp .env.example .env)
#  2. Isi nilai DD_API_KEY dengan API Key dari akun Datadog kamu
#     (Organization Settings -> API Keys).
#  3. Sesuaikan DD_SITE dengan region akunmu:
#       - US1            -> datadoghq.com
#       - EU1            -> datadoghq.eu
#       - AP1 (Asia)     -> ap1.datadoghq.com
#       - US3            -> us3.datadoghq.com
#       - US5            -> us5.datadoghq.com
#
#  PENTING: file .env berisi rahasia. Jangan di-commit ke Git!
#  (sudah dikecualikan lewat .gitignore)
# ============================================================================

DD_API_KEY=tempel_api_key_kamu_di_sini
DD_SITE=datadoghq.com
